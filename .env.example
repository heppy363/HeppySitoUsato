COMPOSE_PROJECT_NAME=heppysitousato

BACKEND_PORT=8000
FRONTEND_PORT=5173
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000

BACKEND_APP_ENV=development
BACKEND_API_HOST=0.0.0.0
BACKEND_API_PORT=8000
BACKEND_REDIS_URL=redis://redis:6379/0
BACKEND_DATABASE_URL=postgresql+asyncpg://heppysito:change_me@postgres:5432/heppysitousato
BACKEND_NETWORK_HTTP2=true
BACKEND_NETWORK_VERIFY_SSL=true
BACKEND_NETWORK_USER_AGENT=HeppySitoUsato/0.1.0
BACKEND_NETWORK_TIMEOUT_CONNECT=5.0
BACKEND_NETWORK_TIMEOUT_READ=10.0
BACKEND_NETWORK_TIMEOUT_WRITE=10.0
BACKEND_NETWORK_TIMEOUT_POOL=5.0
BACKEND_NETWORK_MAX_CONNECTIONS=20
BACKEND_NETWORK_MAX_KEEPALIVE_CONNECTIONS=10
BACKEND_NETWORK_KEEPALIVE_EXPIRY=30.0
BACKEND_NETWORK_RETRY_MAX_ATTEMPTS=3
BACKEND_NETWORK_RETRY_BACKOFF_SECONDS=0.5
BACKEND_NETWORK_RETRY_JITTER_SECONDS=0.1
BACKEND_NETWORK_PROXY_STRATEGY=direct
BACKEND_NETWORK_PROXY_URL=
BACKEND_NETWORK_PROXY_USERNAME=
BACKEND_NETWORK_PROXY_PASSWORD=
BACKEND_EBAY_API_ENVIRONMENT=production
BACKEND_EBAY_API_MARKETPLACE_ID=EBAY_IT
BACKEND_EBAY_API_SCOPE=https://api.ebay.com/oauth/api_scope
BACKEND_EBAY_API_CLIENT_ID=
BACKEND_EBAY_API_CLIENT_SECRET=
BACKEND_EBAY_API_ACCESS_TOKEN=

VITE_API_BASE_URL=http://localhost:8000

POSTGRES_DB=heppysitousato
POSTGRES_USER=heppysito
POSTGRES_PASSWORD=change_me

REDIS_PORT=6379

GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change_me
